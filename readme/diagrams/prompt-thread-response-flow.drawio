        <mxCell id="KN0o1KrCXXuEr38Ueyw9-1" value="Prompt Breakdown:&lt;br&gt;&lt;br&gt;Run in __init__:&lt;br&gt;_setup_gpt_assistants_and_threads()&lt;br&gt;&lt;br&gt;create_assistant(assistant_instructions=ouat_assistant_prompt):&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;ouat_assistant_prompt:&amp;nbsp;&lt;span style=&quot;font-weight: normal;&quot;&gt;&quot;You are designed to tell one line of the story at a time. Respond briefly based on the message history, your responses should never exceed 2 sentences.&quot;&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;br&gt;create_thread(name=&#39;ouat&#39;)&lt;br&gt;" style="text;strokeColor=none;fillColor=none;html=1;fontSize=16;fontStyle=1;verticalAlign=middle;align=left;whiteSpace=wrap;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
